{
  "name": "app-ds-control",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "checked-git-push": "pnpm type-check && git push",
    "deploy-production-update": "eas update --channel main --message 'Update production (channel: main)'",
    "deploy-update-develop-android": "eas update --channel develop --platform android --message 'Update develop'",
    "deploy-full": "eas build --auto-submit",
    "deploy-partial": "eas build --platform ios --profile production --auto-submit --non-interactive & eas build --platform android --profile production --local --non-interactive",
    "eas-set-version": "eas build:version:set"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@hookform/resolvers": "^5.1.1",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@rnmapbox/maps": "^10.1.44",
    "@shopify/flash-list": "1.7.6",
    "@tanstack/react-query": "^5.81.5",
    "@turf/area": "^7.2.0",
    "@turf/centroid": "^7.2.0",
    "@turf/length": "^7.2.0",
    "@turf/turf": "^7.2.0",
    "@types/lodash": "^4.17.20",
    "expo": "~53.0.23",
    "expo-blur": "~14.1.5",
    "expo-constants": "~17.1.7",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.0",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-modules-autolinking": "~2.1.14",
    "expo-modules-core": "~2.5.0",
    "expo-print": "^15.0.7",
    "expo-router": "~5.1.7",
    "expo-screen-orientation": "~8.1.7",
    "expo-sharing": "^14.0.7",
    "expo-speech": "~13.1.7",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-updates": "~0.28.17",
    "expo-web-browser": "~14.2.0",
    "lodash": "^4.17.21",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.60.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/eslintrc": "^3.3.1",
    "@tanstack/eslint-plugin-query": "^5.81.2",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.5.2",
    "@types/react": "~19.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-expo": "^1.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "expo-build-properties": "^0.14.8",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3"
  },
  "private": true
}
