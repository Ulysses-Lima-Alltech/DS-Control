{
  "cli": {
    "version": ">= 16.15.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "abstract-production": {
      "developmentClient": false,
      "distribution": "store",
      "autoIncrement": true,
      "android": {
        "autoIncrement": true
      },
      "ios": {
        "autoIncrement": true
      }
    },
    "preview": {
      "extends": "abstract-production",
      "channel": "develop",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "abstract-production",
      "credentialsSource": "remote",
      "channel": "main",
      "environment": "production",
      "ios": {
        "image": "latest",
        "autoIncrement": true
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6749278332"
      }
    }
  }
}
