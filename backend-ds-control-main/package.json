{
  "name": "ds-drones",
  "version": "0.0.1",
  "description": "DS Drones API",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/server.ts | pino-pretty --colorize",
    "start": "node build/src/server.js",
    "build": "npx swc src --out-dir build --copy-files --ignore \"**/*.test.ts\"",
    "database:generate": "drizzle-kit generate --name",
    "database:migrate": "drizzle-kit migrate",
    "database:push": "drizzle-kit push",
    "database:pull": "drizzle-kit pull",
    "database:up": "drizzle-kit up",
    "database:check": "drizzle-kit check",
    "database:studio": "drizzle-kit studio",
    "database:seed": "tsx src/infra/database/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@types/bcrypt": "6.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.4",
    "pino-pretty": "^13.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.0.2",
    "@fastify/schedule": "^6.0.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.58.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.5.0",
    "fastify-plugin": "^5.0.1",
    "fastify-zod-openapi": "^4.1.2",
    "ioredis": "^5.7.0",
    "jose": "^6.0.13",
